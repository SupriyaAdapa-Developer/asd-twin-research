dmypy.json

# IDE / editors
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Jupyter
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# Quarto
/.quarto/
*_files/
*_cache/
notebooks/*.html
notebooks/*.pdf
notebooks/*_files/

# Generated reports (can be regenerated by quarto render)
reports/*.html
reports/*.pdf

# Generated data — uncomment to exclude from VC; commit if you want reviewers
# to skip the regeneration step
# data/synthetic_cohort.csv
# data/sessions.csv
# data/environmental.csv

# Node / prototypes (if reviewers run vite locally)
node_modules/
prototypes/*/node_modules/
prototypes/*/dist/
prototypes/*/.vite/

# OS
Thumbs.db
.DS_Store

# Docker
.docker/

# Secrets — never commit
*.pem
*.key
.env.local
secrets.yaml
config.local.*
